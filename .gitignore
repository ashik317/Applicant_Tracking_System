# Ignore environment variables file
.env

# Ignore IDE configuration files (for JetBrains IDEs like IntelliJ or PyCharm)
.idea/
idea/
*/idea/

# Ignore Python virtual environment directory
.venv/
venv/
*/venv/

# Ignore Python bytecode files
*.pyc
*.pyo
__pycache__/

# Ignore log files
*.log

# Ignore system files (macOS example)
.DS_Store

# Ignore database files (if any, for example SQLite)
*.db
*.sqlite3
*.pdf

# Ignore Django static files (collected)
staticfiles/

# Ignore Django media/uploads
media/

# Ignore Docker temporary files
*.pid
*.sock

# Ignore entrypoint script (optional, only if you don't want it in Git)
# entrypoint.sh
